# hybrid_input example
# Lines starting with # or // are ignored.

# Simulation control
njob = 0
Nev = 100
cent = 0-5

# Energy loss parameters
kappa = 15.0
alpha = 0.404

tmethod = 0
mode = 0

# Physics toggles
# do_quench: true/false
# do_wake: true/false
# do_source: true/false
# do_elastic: true/false (Moliere elastic scattering integration path)
# do_lres: true/false (finite color-resolution energy-loss path)
# compat_moliere_legacy_hydro: true preserves exact Moliere_code averaged-hydro interpolation.
# Set false to use unified MMI HydroProfile access for Moliere elastic.

do_quench = true
#do_wake = true
#do_source = false
#do_elastic = false
#do_lres = false
#compat_moliere_legacy_hydro = true
#rpower = 2.0

# Validation-only fixed production vertex. Leave disabled for physics runs.
#use_fixed_xy = false
#fixed_x = 0.0
#fixed_y = 0.0

# Hydro mode: 0 = averaged hydro (Hydro_PbPb), 1 = event-by-event (ipsat)
ebe_hydro = 0

# Medium hadronization mode
# hadro_type = 0 : direct PYTHIA hadronization with existing color tags
# hadro_type = 1 : rebuild strings before hadronization (needed for elastic recoilers)
#hadro_type = 0

# Moliere table directory for elastic mode
#tables_path = /raid5/data/yjlee/hybrid_dev/moliere_table_bundle/a10_tables/

# Output base name (files will be <output_base>_Hadrons.out and <output_base>_Partons.out)
output_base = HYBRID

# Trigger options
# use_trigger: if true, only accept events containing the trigger particle
# trigger_id:  PDG id of trigger particle (e.g. 22 = photon, 23 = Z)
# trigger_pt:  minimum pT of trigger particle (GeV)
# trigger_eta: maximum |eta| of trigger particle
#use_trigger = false
#trigger_id = 22
#trigger_pt = 20.0
#trigger_eta = 2.4
