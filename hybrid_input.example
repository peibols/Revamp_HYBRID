# hybrid_input example
# Lines starting with # or // are ignored.

# Simulation control
njob = 0
Nev = 100
cent = 0-5

# Energy loss parameters
kappa = 15.0
alpha = 0.404

tmethod = 0
mode = 0

# Physics toggles
# do_quench: true/false
# do_wake: true/false
# do_source: true/false

do_quench = true
#do_wake = true
#do_source = false

# Hydro mode: 0 = averaged hydro (Hydro_PbPb), 1 = event-by-event (ipsat)
ebe_hydro = 0

# Output base name (files will be <output_base>_Hadrons.out and <output_base>_Partons.out)
output_base = HYBRID

# Trigger options
# use_trigger: if true, only accept events containing the trigger particle
# trigger_id:  PDG id of trigger particle (e.g. 22 = photon, 23 = Z)
# trigger_pt:  minimum pT of trigger particle (GeV)
# trigger_eta: maximum |eta| of trigger particle
#use_trigger = false
#trigger_id = 22
#trigger_pt = 20.0
#trigger_eta = 2.4
